# Proxy server URL for domain checking (local development)
VITE_PROXY_URL=http://localhost:3001

# Password hash for authentication (production)
# Generate using Node.js crypto module with PBKDF2:
# node -e "const crypto = require('crypto'); const salt = crypto.randomBytes(16).toString('hex'); const hash = crypto.pbkdf2Sync('your-password', salt, 100000, 32, 'sha256').toString('hex'); console.log(hash + ':' + salt);"
# Then set VITE_PASSWORD_HASH to the output (hash:salt format)
# Example: VITE_PASSWORD_HASH=abc123...def:xyz789...abc
# If not set, the first password entered will be stored in localStorage with a random salt
VITE_PASSWORD_HASH=

# JWT secret for authentication tokens (REQUIRED for production)
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER use the default in production!
JWT_SECRET=your-secure-jwt-secret-min-32-chars

# Allowed origins for CORS (comma-separated, use * for development)
# In production, specify your domain: https://yourdomain.com
ALLOWED_ORIGINS=*

# Allow initial password setup (development only, NEVER in production)
VITE_ALLOW_INITIAL_LOGIN=false

# Auth session TTL in minutes (default: 720 = 12 hours)
VITE_AUTH_SESSION_TTL_MINUTES=720

# Marketing site URL (for "Website" link in dashboard header)
# Set this to your production marketing site URL
VITE_SITE_URL=http://localhost:3002

# DomainPulse app URL (for "Launch App" link in marketing site)
# Set this to your production dashboard URL
VITE_APP_URL=http://localhost:3000
