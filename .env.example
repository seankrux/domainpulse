# Proxy server URL for domain checking (local development)
VITE_PROXY_URL=http://localhost:3001

# Password hash for authentication (production)
# Generate using: node -e "crypto.subtle.digest('SHA-256', new TextEncoder().encode('your-password')).then(hash => console.log(Array.from(new Uint8Array(hash)).map(b => b.toString(16).padStart(2, '0')).join('')))"
# Or use any online SHA-256 generator
# If not set, the first password entered will be stored in localStorage
VITE_PASSWORD_HASH=
