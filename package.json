{
  "name": "domainpulse",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.site.config.ts",
    "build": "vite build --config vite.site.config.ts",
    "preview": "vite preview --config vite.site.config.ts",
    "dev:app": "vite",
    "build:app": "vite build",
    "build:all": "npm run build && npm run build:app",
    "server": "tsx server/proxy.ts",
    "preview:all": "concurrently \"npm run server\" \"vite preview --port 3000 --host 0.0.0.0\"",
    "dev:all": "concurrently \"npm run server\" \"npm run dev:app\"",
    "lint": "eslint . --ext ts,tsx --format ./eslint-formatter.cjs",
    "lint:fix": "eslint . --ext ts,tsx --fix --format ./eslint-formatter.cjs",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:gui": "playwright test",
    "test:gui:report": "playwright show-report",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "lucide-react": "^0.564.0",
    "marked": "^17.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "recharts": "^3.7.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vercel/node": "^5.6.3",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^1.3.1",
    "autoprefixer": "^10.4.24",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^1.3.1"
  }
}
